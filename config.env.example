# Copy this file to config.env and edit paths/refs for the private server.

# Public OpenTitan source. Set OPENTITAN_REMOTE to an internal mirror if needed.
OPENTITAN_REMOTE="${OPENTITAN_REMOTE:-https://github.com/lowRISC/opentitan.git}"

# Default matches the public chip dashboard report revision recorded by the
# local circtuvm sv-tests selector metadata. Override this to match any newer
# Arcilator-generated OpenTitan wrapper set.
OPENTITAN_REF="${OPENTITAN_REF:-9f20940d494a223cc950a5b98f748fb28109d458}"

WORK_ROOT="${WORK_ROOT:-${HARNESS_ROOT}/work}"
OPENTITAN_ROOT="${OPENTITAN_ROOT:-${WORK_ROOT}/opentitan}"
HARNESS_VENV="${HARNESS_VENV:-${WORK_ROOT}/venv}"

# OpenTitan's current DVSim dependency needs Python 3.10 or newer. The harness
# auto-detects python3.12/python3.11/python3.10/python3; set this on hosts where
# Python is available through an environment module or nonstandard path.
HARNESS_PYTHON="${HARNESS_PYTHON:-}"

# Native OpenTitan DVSim configuration.
DVSIM_CFG="${DVSIM_CFG:-hw/top_earlgrey/dv/chip_sim_cfg.hjson}"
DVSIM_TOOL="${DVSIM_TOOL:-xcelium}"
DVSIM_WAVES="${DVSIM_WAVES:-vcd}"
DVSIM_MAX_PARALLEL="${DVSIM_MAX_PARALLEL:-1}"
DVSIM_MAX_WAVES="${DVSIM_MAX_WAVES:-}"
DVSIM_SCRATCH_ROOT="${DVSIM_SCRATCH_ROOT:-${WORK_ROOT}/dvsim-scratch}"
DVSIM_EXTRA_ARGS="${DVSIM_EXTRA_ARGS:-}"
DVSIM_DRY_RUN="${DVSIM_DRY_RUN:-0}"

# Optional harness-side timeout around each DVSim invocation. This is separate
# from any DVSim internal kill policy and prevents one seed/test group from
# consuming an entire private-server collection window.
DVSIM_GROUP_TIMEOUT="${DVSIM_GROUP_TIMEOUT:-}"
DVSIM_GROUP_TIMEOUT_KILL_AFTER="${DVSIM_GROUP_TIMEOUT_KILL_AFTER:-5m}"

# If auto-detection fails, set DVSIM_BIN to a command such as:
#   DVSIM_BIN="${HARNESS_VENV}/bin/dvsim.py"
#   DVSIM_BIN="${OPENTITAN_ROOT}/util/dvsim/dvsim.py"
DVSIM_BIN="${DVSIM_BIN:-}"

TARGET_FILE="${TARGET_FILE:-${HARNESS_ROOT}/targets/xrun-smoke.tsv}"
PRIVATE_OUT="${PRIVATE_OUT:-${HARNESS_ROOT}/private-xrun}"
USABLE_OUT="${USABLE_OUT:-${HARNESS_ROOT}/usable-emissions}"

# License-conscious default: export only derived summaries and log excerpts.
EXPORT_RAW_WAVES="${EXPORT_RAW_WAVES:-0}"
MAX_RAW_WAVE_BYTES="${MAX_RAW_WAVE_BYTES:-25000000}"
LOG_EXCERPT_LINES="${LOG_EXCERPT_LINES:-220}"
VCD_MAX_SIGNALS="${VCD_MAX_SIGNALS:-200}"
VCD_MAX_EVENTS_PER_SIGNAL="${VCD_MAX_EVENTS_PER_SIGNAL:-64}"

# Partial collection controls. These are useful when private-xrun is hundreds
# of GB and the goal is to transfer targeted evidence, not raw simulator output.
# COLLECT_INCLUDE_PRIVATE_PATH_REGEX filters private-root-relative paths.
# VCD_SIGNATURE_MAX_BYTES makes larger waves header-only instead of scanning
# every value change.
COLLECT_INCLUDE_PRIVATE_PATH_REGEX="${COLLECT_INCLUDE_PRIVATE_PATH_REGEX:-}"
VCD_SIGNATURE_MAX_BYTES="${VCD_SIGNATURE_MAX_BYTES:-}"

# Continue running later targets if one DVSim invocation fails.
STOP_ON_FAIL="${STOP_ON_FAIL:-0}"

# 04_run_overnight_all.sh groups duplicate dashboard rows by test name, then
# runs each group with that test's exact seed list. Leave this off for the
# smoke/frontier scripts unless you explicitly want grouped DVSim jobs.
BATCH_TARGETS="${BATCH_TARGETS:-0}"
BATCH_NAME="${BATCH_NAME:-}"
PURGE_RUN_ROOT="${PURGE_RUN_ROOT:-0}"

# Optional safety valve for huge per-test seed groups. When set to a positive
# integer, grouped batch mode splits each test's exact seed list into chunks of
# at most this many seeds. This still covers the same concrete dashboard rows,
# but makes long private-server runs easier to stop, inspect, and partially
# collect.
BATCH_GROUP_MAX_SEEDS="${BATCH_GROUP_MAX_SEEDS:-}"
